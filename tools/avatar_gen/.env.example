# Gemini (Google AI Studio key: https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.0-flash

# Cloudflare Workers AI (https://dash.cloudflare.com -> AI -> Workers AI)
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_API_TOKEN=your-workers-ai-token
# FLUX (default) or SDXL: @cf/stabilityai/stable-diffusion-xl-base-1.0
CF_IMAGE_MODEL=@cf/black-forest-labs/flux-1-schnell

# Pipeline options
HOST_IMAGES=true
MAX_ATTEMPTS=3
OUT_DIR=tools/avatar_gen/out
